// Solar Ops MVP - Prisma Schema
// Supports: Owner submission, Admin validation, Scaffolder quotes, Scheduling, Site Reports

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// AUTH & USERS
// ──────────────────────────────────────────────

enum Role {
  ADMIN
  OWNER
  SCAFFOLDER
  ENGINEER
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String
  role           Role
  isActive       Boolean   @default(true)
  emailVerified  Boolean   @default(false)
  mfaEnabled     Boolean   @default(false)
  mfaSecret      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  // Relations
  ownerProfile    Owner?
  scaffolderProfile Scaffolder?
  engineerProfile  Engineer?
  sessions        Session[]
  auditLogs       AuditLog[]
  notifications   Notification[]

  @@index([email])
  @@index([role])
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String   @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([refreshToken])
}

model PasswordReset {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  verifiedAt DateTime?
  createdAt DateTime @default(now())

  @@index([token])
}

// ──────────────────────────────────────────────
// CONSENT & PRIVACY
// ──────────────────────────────────────────────

model ConsentRecord {
  id          String   @id @default(uuid())
  userId      String
  consentType String   // e.g. "terms_v1", "privacy_v1", "marketing"
  granted     Boolean
  grantedAt   DateTime @default(now())
  ipAddress   String?

  @@unique([userId, consentType])
  @@index([userId])
}

// ──────────────────────────────────────────────
// PROPERTY & OWNER
// ──────────────────────────────────────────────

model Owner {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  firstName       String
  lastName        String
  phone           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  properties      Property[]

  @@index([userId])
}

model Property {
  id              String    @id @default(uuid())
  ownerId          String
  owner           Owner      @relation(fields: [ownerId], references: [id])
  addressLine1    String
  addressLine2    String?
  city            String
  postcode        String
  latitude        Float?
  longitude       Float?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  jobs            Job[]

  @@index([ownerId])
  @@index([postcode])
}

// ──────────────────────────────────────────────
// SCAFFOLDER / CONTRACTOR
// ──────────────────────────────────────────────

model Scaffolder {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  companyName     String
  firstName       String
  lastName        String
  phone           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  regions         ScaffolderRegion[]
  assignments     JobAssignment[]
  quotes          Quote[]

  @@index([userId])
  @@index([isActive])
}

model Region {
  id        String   @id @default(uuid())
  name      String   @unique  // e.g. "North Ireland", "South West"
  code      String   @unique  // e.g. "NI", "SW"
  createdAt DateTime @default(now())

  scaffolders ScaffolderRegion[]
  @@index([name])
}

model ScaffolderRegion {
  id           String     @id @default(uuid())
  scaffolderId String
  scaffolder   Scaffolder @relation(fields: [scaffolderId], references: [id], onDelete: Cascade)
  regionId     String
  region       Region     @relation(fields: [regionId], references: [id])

  @@unique([scaffolderId, regionId])
  @@index([scaffolderId])
  @@index([regionId])
}

// ──────────────────────────────────────────────
// ENGINEER / INSTALLER
// ──────────────────────────────────────────────

model Engineer {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  firstName       String
  lastName        String
  phone           String?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  siteReports     SiteReport[]

  @@index([userId])
}

// ──────────────────────────────────────────────
// JOB LIFECYCLE
// ──────────────────────────────────────────────

enum JobStatus {
  DRAFT
  AWAITING_OWNER_SUBMISSION
  SUBMITTED
  NEEDS_MORE_INFO
  VALIDATED
  ASSIGNED_TO_SCAFFOLDER
  QUOTE_PENDING
  QUOTE_SUBMITTED
  QUOTE_REVISION_REQUESTED
  QUOTE_APPROVED
  QUOTE_REJECTED
  SCHEDULING_IN_PROGRESS
  SCHEDULED
  SCAFFOLD_WORK_IN_PROGRESS
  SCAFFOLD_COMPLETE
  INSTALLER_ASSIGNED
  SITE_REPORT_PENDING
  SITE_REPORT_IN_PROGRESS
  SITE_REPORT_SUBMITTED
  COMPLETED
  CANCELLED
  ON_HOLD
}

model Job {
  id              String      @id @default(uuid())
  propertyId      String
  property        Property     @relation(fields: [propertyId], references: [id])
  status          JobStatus   @default(DRAFT)
  statusReason    String?     // e.g. "Photos blurry", "Missing roof angle"
  adminNotes      String?     // Internal admin notes
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  completedAt     DateTime?

  // Job invite
  inviteToken     String?      @unique
  inviteSentAt    DateTime?
  inviteExpiresAt DateTime?

  // Relations
  statusHistory   JobStatusHistory[]
  assignments     JobAssignment[]
  photos          JobPhoto[]
  quotes          Quote[]
  schedules       Schedule[]
  siteReports     SiteReport[]
  comments        Comment[]
  notifications   Notification[]

  @@index([propertyId])
  @@index([status])
  @@index([inviteToken])
}

model JobStatusHistory {
  id        String    @id @default(uuid())
  jobId     String
  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  fromStatus JobStatus?
  toStatus  JobStatus
  changedBy String    // UserId
  note      String?
  createdAt DateTime  @default(now())

  @@index([jobId])
  @@index([createdAt])
}

model JobAssignment {
  id           String     @id @default(uuid())
  jobId        String
  job          Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scaffolderId String
  scaffolder   Scaffolder @relation(fields: [scaffolderId], references: [id])
  assignedAt   DateTime   @default(now())
  assignedBy   String     // Admin UserId
  isActive     Boolean    @default(true)

  @@index([jobId])
  @@index([scaffolderId])
}

// ──────────────────────────────────────────────
// PHOTOS & FILES
// ──────────────────────────────────────────────

enum PhotoCategory {
  EXTERIOR_FRONT
  EXTERIOR_REAR
  EXTERIOR_SIDE_LEFT
  EXTERIOR_SIDE_RIGHT
  ROOF_OVERVIEW
  ROOF_PANEL_AREA
  ACCESS_CONSTRAINTS
  HEIGHT_REFERENCE
  OBSTACLE_CLOSEUP
  SCAFFOLD_COMPLETION
  SITE_REPORT_ATTACHMENT
}

enum PhotoReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model JobPhoto {
  id           String           @id @default(uuid())
  jobId        String
  job          Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploaderId   String           // UserId
  category     PhotoCategory
  fileName     String
  storageKey   String           // S3 key
  thumbnailKey String?
  mimeType     String
  fileSize     Int
  latitude     Float?
  longitude    Float?
  reviewStatus PhotoReviewStatus @default(PENDING)
  reviewNote   String?
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  @@index([jobId])
  @@index([category])
  @@index([reviewStatus])
}

// ──────────────────────────────────────────────
// QUOTES
// ──────────────────────────────────────────────

model Quote {
  id              String    @id @default(uuid())
  jobId           String
  job             Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  scaffolderId    String
  scaffolder      Scaffolder @relation(fields: [scaffolderId], references: [id])
  amount          Decimal   @db.Decimal(10, 2)
  currency        String    @default("GBP")
  notes           String?   // Assumptions, exclusions
  proposedDate    DateTime?
  status          QuoteStatus @default(PENDING)
  submittedAt     DateTime  @default(now())
  reviewedBy      String?   // Admin UserId
  reviewedAt      DateTime?
  revisionNote    String?   // Admin note if revision requested
  version         Int       @default(1)

  @@index([jobId])
  @@index([scaffolderId])
  @@index([status])
}

enum QuoteStatus {
  PENDING
  SUBMITTED
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

// ──────────────────────────────────────────────
// SCHEDULING
// ──────────────────────────────────────────────

model Schedule {
  id           String         @id @default(uuid())
  jobId        String
  job          Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  proposedDate DateTime
  proposedBy   String         // Admin UserId
  proposedAt   DateTime       @default(now())
  status       ScheduleStatus @default(PROPOSED)
  confirmedAt  DateTime?
  confirmedBy  String?
  cancelledAt  DateTime?
  cancelledBy  String?
  note         String?

  @@index([jobId])
  @@index([status])
}

enum ScheduleStatus {
  PROPOSED
  CONFIRMED
  RESCHEDULE_REQUESTED
  CANCELLED
}

// ──────────────────────────────────────────────
// SITE REPORTS
// ──────────────────────────────────────────────

model SiteReport {
  id           String    @id @default(uuid())
  jobId        String
  job          Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  engineerId   String
  engineer     Engineer  @relation(fields: [engineerId], references: [id])
  status       ReportStatus @default(DRAFT)
  data         Json      // Dynamic questionnaire answers
  pdfStorageKey String?  // S3 key for generated PDF
  submittedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([jobId])
  @@index([engineerId])
  @@index([status])
}

enum ReportStatus {
  DRAFT
  IN_PROGRESS
  SUBMITTED
}

// ──────────────────────────────────────────────
// COMMENTS / COMMUNICATION
// ──────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  authorId  String
  authorRole Role
  content   String
  isInternal Boolean @default(false) // Admin-only comments
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([createdAt])
}

// ──────────────────────────────────────────────
// NOTIFICATIONS
// ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id])
  type      String   // e.g. "PHOTOS_APPROVED", "QUOTE_SUBMITTED"
  title     String
  body      String
  data      Json?    // Extra payload
  isRead    Boolean  @default(false)
  sentAt    DateTime @default(now())

  @@index([userId])
  @@index([jobId])
  @@index([isRead])
}

// ──────────────────────────────────────────────
// NOTIFICATION TEMPLATES (admin-configurable)
// ──────────────────────────────────────────────

model NotificationTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  titleTemplate String
  bodyTemplate String
  emailSubject String?
  emailBody    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ──────────────────────────────────────────────
// AUDIT LOG
// ──────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  action     String   // e.g. "JOB_STATUS_CHANGED", "PHOTO_APPROVED"
  entityType String   // e.g. "Job", "User", "Quote"
  entityId   String
  changes    Json?    // Before/after diff
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
