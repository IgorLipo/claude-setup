NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
DATABASE_URL="postgresql://postgres:password@localhost:5432/solar_ops?schema=public"
JWT_SECRET=change-me-in-production-use-32-char-secret
JWT_REFRESH_SECRET=change-me-in-production-use-64-char-secret
JWT_EXPIRES_IN=15m
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=solar-ops-uploads
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=noreply@solarops.co.uk
REDIS_URL=redis://localhost:6379
